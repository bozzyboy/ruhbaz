# agent/.env örneği — GERÇEK DEĞERLERİ BURAYA DEĞİL, agent/.env'e yaz (o dosya .gitignore'da).

# Gemini API anahtarı (Google AI Studio)
GOOGLE_API_KEY=buraya-gercek-anahtar

# App ile paylaşılan gizli. /gemini-generate ve /gemini-embed bu olmadan ÇALIŞMAZ.
# Aynı değer mobile/.env.local içinde EXPO_PUBLIC_AGENT_SHARED_SECRET olarak durmalı.
# Üretmek için (PowerShell): -join ((1..64) | ForEach-Object { '0123456789abcdef'[(Get-Random -Maximum 16)] })
AGENT_SHARED_SECRET=buraya-rastgele-64-hex

# Telefon LAN'dan bağlanacaksa 0.0.0.0; yalnız PC'de test için 127.0.0.1 (varsayılan).
HOST=0.0.0.0

# İsteğe bağlı ayarlar (varsayılanlar token_server.py içinde):
# PORT=8080
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2
